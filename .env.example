# Frontend (Vite) — copy to .env and fill in to enable real AI map generation.
# Without these the app runs fully on mock agents.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side (NOT a VITE_ var — never expose this to the browser).
# Set on Supabase instead:  supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=
